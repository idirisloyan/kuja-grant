web: python -c "import os; path='.build-sha'; existing=open(path).read().strip() if os.path.exists(path) else ''; sha=os.environ.get('RAILWAY_GIT_COMMIT_SHA','')[:12] or os.environ.get('SOURCE_VERSION','')[:12]; open(path,'w').write(sha or existing or 'unknown')" && python pre_deploy.py && flask db upgrade && gunicorn --bind 0.0.0.0:${PORT:-5000} --workers 4 --threads 4 --timeout 180 --worker-class gthread --max-requests 1000 --max-requests-jitter 50 --preload server:app
